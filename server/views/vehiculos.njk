<div class="row g-4 justify-content-center">
    {% for vehiculo in vehiculos %}
        <div class="col-md-6 col-lg-4 animate-fade-in">
            <div class="card h-100 border-0 shadow-sm">
                <div class="position-relative">
                    {% if vehiculo.imagenes and vehiculo.imagenes.length > 0 %}
                        <img src="{{ vehiculo.imagenes[0] }}" class="card-img-top" alt="{{ vehiculo.marca.marca if vehiculo.marca else 'Desconocida' }} {{ vehiculo.modelo.modelo if vehiculo.modelo else 'Desconocido' }}" style="height: 220px; object-fit: cover;">
                        {% else %}
                            <div class="bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center" style="height: 220px;">
                                <i class="fas fa-car fs-1 opacity-10"></i>
                            </div>
                        {% endif %}
                        <div class="position-absolute top-0 end-0 m-3">
                            <span class="badge bg-white text-dark shadow-sm">{{ vehiculo.anio }}</span>
                        </div>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold m-0 text-primary">
                                {{ vehiculo.marca.marca if vehiculo.marca else "Desconocida" }}
                                {{ vehiculo.modelo.modelo if vehiculo.modelo else "Desconocido" }}
                            </h5>
                            <span class="fw-bold fs-5">{{ vehiculo.precio | int }} €</span>
                        </div>
                        <div class="d-flex gap-3 mb-3">
                            <span class="small text-muted">
                                <i class="fas fa-gas-pump me-1"></i>
                                {{ vehiculo.combustible }}</span>
                            <span class="small text-muted">
                                <i class="fas fa-road me-1"></i>
                                {{ vehiculo.km | int }} km</span>
                        </div>
                        <hr class="opacity-10 my-3">
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <div class="d-flex gap-1">
                                    <span class="badge bg-dark">
                                        <i class="fas fa-info-circle me-1"></i>
                                        {{ vehiculo.tipo }}</span>
                                    <span class="badge bg-dark">
                                        <i class="fas fa-bolt me-1"></i>
                                        {{ vehiculo.cv }} CV</span>
                                </div>
                                <div class="btn-group shadow-sm">
                                    <a href="/detalle/{{ vehiculo._id }}" class="btn btn-outline-dark btn-sm px-3" title="Ver ficha">
                                        Ficha
                                    </a>
                                    {% if usuarioSesion and (usuarioSesion.rol == 'admin' or (vehiculo.usuario and vehiculo.usuario == usuarioSesion._id)) %}
                                        <a href="/editar/{{ vehiculo._id }}" class="btn btn-outline-primary btn-sm px-2" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form
                                            style="display:inline"
                                            action="/{{ vehiculo._id }}"
                                            method="post"
                                            onsubmit="return confirm('¿Estás seguro de que quieres borrar este vehículo?');">
                                            <input type="hidden" name="_method" value="delete"/>
                                            <button
                                                type="submit"
                                                class="btn btn-outline-danger btn-sm px-2"
                                                title="Borrar"
                                                style="border-top-left-radius: 0; border-bottom-left-radius: 0;">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>