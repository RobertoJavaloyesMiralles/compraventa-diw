<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Compraventa Vehículos | Tu próximo coche está aquí</title>
        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link
        href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300..700&display=swap" rel="stylesheet"> <!-- Font Awesome -->
        <link
        rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"> <!-- Bootstrap CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        {% if isDev() %}
            <script type="module" src="http://localhost:5173/js/main.js"></script>
        {% else %}
            {% for cssFile in viteCssFiles() %}
                <link rel="stylesheet" href="{{ cssFile }}">
            {% endfor %}
            <script type="module" src="{{ viteAsset() }}"></script>
        {% endif %}
        <!-- Bootstrap JS Bundle -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    </head>
    <body class="d-flex flex-column min-vh-100">
        <nav
            class="navbar navbar-expand-lg navbar-dark sticky-top"
            style="background-color: #44749d !important; z-index: 1030 !important;">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" href="/">
                    <span class="fw-bold">CompraVenta</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" href="/catalogo">Catálogo</a>
                        </li>
                        {% if usuarioSesion and usuarioSesion.rol == 'admin' %}
                            <li class="nav-item">
                                <a class="nav-link px-3" href="/usuarios/administracion">Administración</a>
                            </li>
                        {% endif %}
                        {% if usuarioSesion %}
                            <li class="nav-item">
                                <a class="nav-link btn btn-primary border border-white px-3 mx-2" href="/nuevo">Nuevo vehículo</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-dark" href="/usuarios/logout">Logout</a>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="btn btn-dark" href="/usuarios/login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary border border-white px-3 mx-2" href="/usuarios/registro">Registro</a>
                            </li>
                        {% endif %}
                    </ul>

                </div>
            </div>
        </nav>
        <main class="flex-grow-1"> {% block contenido %}{% endblock %}
            </main>
            <footer class="text-center py-4 mt-auto" style="background-color: #44749d !important; color: white !important;">
                <div class="container">
                    <p>Proyecto DIW | Roberto Javaloyes, David Plaza e Iván Sáez-Bravo</p>
                </div>
            </footer>
        </body>
    </html>