{% extends 'base.njk' %}

{% block contenido %}
<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-6">

      <h4 class="mb-4" style="color: #44749d;">
        <i class="fa-solid fa-user-pen me-2"></i>Editar usuario
      </h4>

      {% include "alerta_error.njk" %}

      <form action="/usuarios/{{ usuario._id }}" method="POST">
        <input type="hidden" name="_method" value="PUT">

        <div class="mb-3">
          <label class="form-label" for="nombre">Nombre</label>
          <input type="text" class="form-control" id="nombre" name="nombre"
                 value="{{ usuario.nombre }}" required>
        </div>

        <div class="mb-3">
          <label class="form-label" for="email">Email</label>
          <input type="email" class="form-control" id="email" name="email"
                 value="{{ usuario.email }}" required>
        </div>

        <div class="mb-3">
          <label class="form-label" for="password">Nueva contraseña</label>
          <input type="password" class="form-control" id="password" name="password"
                 placeholder="Dejar en blanco para no cambiarla">
        </div>

        <div class="mb-4">
          <label class="form-label" for="rol">Rol</label>
          <select class="form-select" id="rol" name="rol">
            <option value="user"  {% if usuario.rol == 'user'  %}selected{% endif %}>Usuario</option>
            <option value="admin" {% if usuario.rol == 'admin' %}selected{% endif %}>Administrador</option>
          </select>
        </div>

        <button type="submit" class="btn text-white me-2" style="background-color:#44749d">
          Guardar cambios
        </button>
        <a href="/usuarios/administracion" class="btn btn-outline-secondary">Cancelar</a>
      </form>

    </div>
  </div>
</div>
{% endblock %}
