{% extends "base.njk" %}
{% block contenido %}
    <div class="container my-5">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <h2 class="fw-bold m-0 text-primary">Catálogo de Vehículos</h2>
            <span class="badge bg-primary fs-6">{{ totalVehiculos }} disponibles</span>
        </div>
        <div
            class="row g-5">
            {# --- Columna filtros --- #}
            <aside class="col-lg-3">
                <div class="card p-4 sticky-top shadow-sm border-0 bg-accent" style="top: 100px;">
                    <h5 class="fw-bold mb-4 d-flex align-items-center">
                        <i class="fas fa-sliders-h me-2 text-primary"></i>
                        Filtros
                    </h5>
                    <form action="/catalogo" method="GET">
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase opacity-50">Búsqueda rápida</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">
                                    <i class="fas fa-search text-muted small"></i>
                                </span>
                                <input type="text" name="texto" class="form-control border-start-0" placeholder="Modelo..." value="{{ query.texto if query else '' }}"></div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-uppercase opacity-50">Tipo</label>
                                <select name="tipo" class="form-select">
                                    <option value="">Todos</option>
                                    <option value="Coche" {{ 'selected' if query.tipo == 'Coche' }}>Turismo</option>
                                    <option value="Moto" {{ 'selected' if query.tipo == 'Moto' }}>Motocicleta</option>
                                </select>
                            </div>
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-uppercase opacity-50">Marca</label>
                                <select name="marca" class="form-select">
                                    <option value="">Todas</option>
                                    {% for m in marcas %}
                                        <option value="{{ m._id }}" {{ 'selected' if query.marca == m._id }}>
                                            {{ m.marca }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-uppercase opacity-50">Ordenar por</label>
                                <select name="orden" class="form-select">
                                    <option value="">Por defecto</option>
                                    <option value="precio_asc" {{ 'selected' if query.orden == 'precio_asc' }}>Precio: más bajo</option>
                                    <option value="precio_desc" {{ 'selected' if query.orden == 'precio_desc' }}>Precio: más alto</option>
                                    <option value="anio_desc" {{ 'selected' if query.orden == 'anio_desc' }}>Más recientes</option>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary w-100 mb-2">
                                <i class="fas fa-sync-alt me-1"></i>
                                Aplicar
                            </button>
                            <a href="/catalogo" class="btn btn-link w-100 text-decoration-none text-muted small">Limpiar filtros</a>
                        </form>
                    </div>
                </aside>
                {# --- Columna resultados --- #}
                <div class="col-lg-9">
                    {% if vehiculos.length == 0 %}
                        <div class="text-center py-5">
                            <div class="fs-1 mb-3 text-muted opacity-25">
                                <i class="fas fa-search"></i>
                            </div>
                            <h3 class="fw-bold">No hay resultados</h3>
                            <p class="text-muted">Prueba a ajustar tus filtros de búsqueda.</p>
                            <a href="/catalogo" class="btn btn-primary mt-3">Ver todo el catálogo</a>
                        </div>
                    {% else %}
                        {% include 'vehiculos.njk' %}
                    {% endif %}
                </div>
            </div>
        </div>
        {% if totalPaginas > 1 %}
            <div class="d-flex justify-content-center mt-5">
                <nav>
                    <ul class="pagination gap-1">
                        <li class="page-item {{ 'disabled' if pagina == 1 }}">
                            <a class="page-link rounded-pill px-3" href="/catalogo?{{ query | urlencode }}&pagina={{ pagina - 1 }}">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>
                        {% for i in range(1, totalPaginas + 1) %}
                            <li class="page-item {{ 'active' if i == pagina }}">
                                <a class="page-link rounded-pill px-3" href="/catalogo?{{ query | urlencode }}&pagina={{ i }}">
                                    {{ i }}
                                </a>
                            </li>
                        {% endfor %}
                        <li class="page-item {{ 'disabled' if pagina == totalPaginas }}">
                            <a class="page-link rounded-pill px-3" href="/catalogo?{{ query | urlencode }}&pagina={{ pagina + 1 }}">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        {% endif %}
    {% endblock %}