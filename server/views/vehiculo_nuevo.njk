{% extends "base.njk" %}

{% block contenido %}
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Añadir Nuevo Vehículo</h4>
                </div>
                <div class="card-body p-4">
                    <form action="/" method="POST">
                        <div class="row g-3">
                            <!-- Matrícula -->
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Matrícula</label>
                                <input type="text" name="matricula" class="form-control" placeholder="1234ABC">
                                <div class="form-text small">Formato: 1234ABC</div>
                            </div>
                            
                            <!-- Marca -->
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Marca</label>
                                <select name="marca" class="form-select">
                                    <option value="" selected disabled>Selecciona marca...</option>
                                    {% for m in marcas %}
                                        <option value="{{ m._id }}">{{ m.marca }}</option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Modelo</label>
                                <select name="modelo" class="form-select">
                                    <option value="" selected disabled>Selecciona modelo...</option>
                                    {% for mod in modelos %}
                                        <option value="{{ mod._id }}">{{ mod.modelo }}</option>
                                    {% endfor %}
                                </select>
                            </div>

                            <!-- Precio y Año -->
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Precio (€)</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-euro-sign"></i></span>
                                    <input type="number" name="precio" class="form-control">
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Año de Fabricación</label>
                                <input type="number" name="anio" class="form-control">
                            </div>

                            <!-- Motor y Kilómetros -->
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Potencia (CV)</label>
                                <input type="number" name="cv" class="form-control">
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Kilómetros</label>
                                <input type="number" name="km" class="form-control">
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Cilindrada (cc)</label>
                                <input type="number" name="cilindrada" class="form-control">
                            </div>

                            <!-- Desplegables de Tipo -->
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Combustible</label>
                                <select name="combustible" class="form-select">
                                    <option value="gasolina">Gasolina</option>
                                    <option value="diesel">Diésel</option>
                                    <option value="electrico">Eléctrico</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Tipo</label>
                                <select name="tipo" class="form-select">
                                    <option value="Coche">Coche</option>
                                    <option value="Moto">Moto</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Subtipo</label>
                                <select name="subtipo" class="form-select">
                                    <option value="" selected disabled>Selecciona subtipo...</option>
                                    <option value="Deportivo">Deportivo</option>
                                    <option value="SUV">SUV</option>
                                    <option value="Compacto">Compacto</option>
                                    <option value="Sedán">Sedán</option>
                                    <option value="Scooter">Scooter</option>
                                    <option value="Deportiva">Deportiva</option>
                                    <option value="Trial">Trial</option>
                                    <option value="Trail">Trail</option>
                                    <option value="Moto-Cross">Moto-Cross</option>
                                </select>
                            </div>

                            <!-- Botones -->
                            <div class="col-12 mt-4 pt-3 border-top">
                                <button type="submit" class="btn btn-primary px-5 py-2 shadow-sm">
                                    <i class="fas fa-save me-2"></i>Guardar Vehículo
                                </button>
                                <a href="/" class="btn btn-outline-secondary px-4 py-2 ms-2">Cancelar</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
